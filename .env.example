# ─── Required ─────────────────────────────────────────────────────────────────

# OpenAI-compatible API key for summarization
OPENAI_API_KEY=sk-your-openai-api-key

# SendGrid API key for email delivery
SENDGRID_API_KEY=SG.your-sendgrid-api-key

# ─── Optional ─────────────────────────────────────────────────────────────────

# Override default model (default: gpt-4o-mini — cheap and good enough)
OPENAI_MODEL=gpt-4o-mini

# If using a different OpenAI-compatible provider (e.g. Azure, Together, Groq)
# Leave blank to use OpenAI default
OPENAI_BASE_URL=

# Email recipients and sender
RECIPIENT_EMAIL=marct191@gmail.com
FROM_EMAIL=alerts@yourdomain.com

# Your GitHub Pages dashboard URL (used in email links)
DASHBOARD_URL=https://your-username.github.io/ai-news-dashboard/

# Optional: GitHub token for higher-rate GitHub API calls
GITHUB_TOKEN=ghp_your-personal-access-token
