{
  "name": "ai-news-dashboard",
  "version": "1.0.0",
  "description": "Daily AI news intelligence dashboard with email digest",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node scripts/runDaily.js",
    "fetch": "node scripts/fetchSources.js",
