  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.3",
    "fast-xml-parser": "^4.4.1",
    "natural": "^8.0.1",
    "node-fetch": "^3.3.2",
    "openai": "^4.67.3"
  },
  "devDependencies": {}
}
